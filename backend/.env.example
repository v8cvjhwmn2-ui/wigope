# Database
MONGO_URI=

# Redis (Upstash REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SMS Provider (InboxRaja DLT)
SMS_PROVIDER=inboxraja
INBOXRAJA_API_KEY=
INBOXRAJA_SENDER_ID=WIGOPE
INBOXRAJA_TEMPLATE_ID=
INBOXRAJA_BASE_URL=https://web.inboxraja.in/dev

# Razorpay Wallet Top-up
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Hubble Rewards SDK
HUBBLE_X_SECRET=
HUBBLE_SSO_TTL_SECONDS=900
HUBBLE_WEBHOOK_SECRET=

# KwikAPI Recharge UAT
KWIKAPI_BASE_URL=https://uat.kwikapi.com
KWIKAPI_API_KEY=
KWIKAPI_WEBHOOK_SECRET=
KWIKAPI_ENVIRONMENT=uat
RECHARGE_MIN_AMOUNT=10
RECHARGE_MAX_AMOUNT=10000
RECHARGE_DAILY_LIMIT=20000
RECONCILE_INTERVAL_MINUTES=5
RECONCILE_MAX_AGE_MINUTES=30

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP behaviour
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_SEND_RATE_LIMIT_PER_HOUR_MOBILE=3
OTP_SEND_RATE_LIMIT_PER_HOUR_IP=10

# App
NODE_ENV=development
PORT=4000
APP_NAME=Wigope Pay
ADMIN_PANEL_SECRET=
SKIP_INFRA_CONNECT=false
PII_ENCRYPTION_KEY=
LOG_LEVEL=info

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3002
